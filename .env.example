# Payment Gateway Configuration
NEXT_PUBLIC_PAYMENT_API_URL=https://api.payment.com
PAYMENT_API_SECRET=your_payment_secret_key

# Database/Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001
API_SECRET_KEY=your_api_secret_key

# Image CDN
NEXT_PUBLIC_IMAGE_CDN=https://cdn.example.com

# Email Service
NEXT_PUBLIC_MAIL_SERVICE_ID=your_mail_service_id
MAIL_SERVICE_SECRET=your_mail_service_secret

# Currency & Region
NEXT_PUBLIC_CURRENCY=EGP
NEXT_PUBLIC_DEFAULT_REGION=Egypt

# Sentry/Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
